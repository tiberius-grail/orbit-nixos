{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "nix"
      ],
      "automerge": true,
      "labels": [
        "dependencies"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "automerge": false,
      "groupName": "github-actions-monthly",
      "extends": [
        "schedule:monthly"
      ],
      "labels": [
        "dependencies"
      ]
    }
  ]
}
